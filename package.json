{
  "name": "hugo-shortcodes",
  "displayName": "Hugo Shortcodes",
  "description": "Syntax highlighting and completions for Hugo shortcodes in Markdown.",
  "license": "MIT",
  "version": "0.1.0",
  "publisher": "thuliteio",
  "repository": {
    "type": "git",
    "url": "https://github.com/thuliteio/hugo-shortcodes.git"
  },
  "homepage": "https://github.com/thuliteio/hugo-shortcodes#readme",
  "bugs": {
    "url": "https://github.com/thuliteio/hugo-shortcodes/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "hugo",
    "shortcode",
    "shortcodes",
    "markdown",
    "thulite",
    "doks"
  ],
  "galleryBanner": {
    "color": "#1F6FEB",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:markdown",
    "workspaceContains:**/layouts/_shortcodes/*.html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Hugo Shortcodes",
      "properties": {
        "hugoShortcodes.additionalSearchGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/@thulite/doks-core/layouts/_shortcodes/*.html",
            "**/node_modules/@thulite/images/layouts/_shortcodes/*.html",
            "**/node_modules/@thulite/inline-svg/layouts/_shortcodes/*.html"
          ],
          "description": "Additional workspace globs to discover shortcode templates. Use this for custom mount layouts."
        }
      }
    },
    "grammars": [
      {
        "scopeName": "text.hugo-shortcode.markdown",
        "path": "./syntaxes/hugo-shortcodes.tmLanguage.json",
        "injectTo": [
          "text.html.markdown",
          "text.html.markdown.gfm"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.7.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "overrides": {
    "diff": "8.0.4",
    "serialize-javascript": "7.0.5"
  }
}
